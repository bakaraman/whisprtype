{
  "name": "whisprtype",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first macOS dictation with hotkeys, whisper.cpp, and paste-anywhere automation.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "preview": "vite preview",
    "tauri": "tauri",
    "assets:readme": "node ./scripts/capture-readme-screenshots.mjs",
    "assets:bundle-whisper": "node ./scripts/bundle-whisper-assets.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
